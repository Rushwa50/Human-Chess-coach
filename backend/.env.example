APP_NAME="Chess Human Coach AI"
DATABASE_URL="sqlite+aiosqlite:///./chess_coach.db"
JWT_SECRET_KEY="change-this-in-production"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=10080

# Production/Docker: Stockfish runs on the backend server, not user laptops.
# Docker image installs official Stockfish 18 at /usr/local/bin/stockfish18.
# Local Windows example: C:/stockfish/stockfish-windows-x86-64-avx2.exe
STOCKFISH_PATH="stockfish"
STOCKFISH_DEPTH=16
STOCKFISH_TIME_LIMIT=0.0
STOCKFISH_THREADS=1
STOCKFISH_HASH_MB=128
STOCKFISH_CLEAR_HASH_EACH_POSITION=true

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"
