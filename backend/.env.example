APP_NAME="Chess Human Coach AI"
DATABASE_URL="sqlite+aiosqlite:///./chess_coach.db"
JWT_SECRET_KEY="change-this-in-production"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=10080

# Install Stockfish locally and set the absolute path.
# Windows example: C:\stockfish\stockfish-windows-x86-64-avx2.exe
# macOS/Linux example: /usr/local/bin/stockfish
STOCKFISH_PATH=""
STOCKFISH_DEPTH=12
STOCKFISH_TIME_LIMIT=0.15

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"
